ANTHROPIC_API_KEY=        # Optional — only needed if LLM_PROVIDER=anthropic
OPENROUTER_API_KEY=       # Optional — only needed if LLM_PROVIDER=openrouter
GROQ_API_KEY=             # Free — get from console.groq.com (recommended)
VAPI_API_KEY=          # Private Key — for creating assistants + outbound calls
VAPI_PUBLIC_KEY=       # Public Key  — for web calls (browser-based)
VAPI_PHONE_NUMBER_ID=
DATABASE_URL=postgresql://riverline:riverline@localhost:5432/riverline
TEMPORAL_ADDRESS=localhost:7233
PORT=3000
COMPANY_NAME="Riverline Financial"
EVAL_SEED=42

# LLM provider: groq (free) | openrouter | anthropic
LLM_PROVIDER=openrouter

# Override default models (optional)
# AGENT_MODEL=google/gemini-2.5-flash
# EVAL_MODEL=google/gemini-2.0-flash-lite
