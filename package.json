{
  "name": "riverline-collections",
  "version": "1.0.0",
  "description": "Self-learning AI debt collections agent pipeline",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "worker": "tsx src/temporal/worker.ts",
    "api": "tsx src/api/server.ts",
