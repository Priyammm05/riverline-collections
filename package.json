    "@temporalio/worker": "^1.11.4",
    "@temporalio/workflow": "^1.11.4",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "js-tiktoken": "^1.0.15",
    "openai": "^6.38.0",
    "pg": "^8.13.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
